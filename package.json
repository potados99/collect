{
  "name": "collect",
  "version": "2.0.0",
  "description": "감자도스 텍스트 수집기",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/potados99/collect.git"
  },
  "author": "potados99",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && pnpm copy-views",
    "copy-views": "copyfiles -u 1 \"src/**/*.pug\" dist",
    "start": "node dist/index.js",
    "test": "jest",
    "lint": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^4.21.2",
    "pug": "^3.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "@types/pug": "^2.0.10",
    "@types/supertest": "^6.0.2",
    "copyfiles": "^2.4.1",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "prettier": {
    "printWidth": 120
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ]
  }
}
